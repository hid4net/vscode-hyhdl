{
    "comments": {
        "lineComment": "//",
        "blockComment": [ "/*", "*/" ]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["begin", "end"],
        ["case", "endcase"],
        ["casex", "endcase"],
        ["casez", "endcase"],
        ["config", "endconfig"],
        ["fork", "join"],
        ["function", "endfunction"],
        ["generate", "endgenerate"],
        ["macromodule", "endmodule"],
        ["module", "endmodule"],
        ["primitive", "endprimitive"],
        ["specify", "endspecify"],
        ["table", "endtable"],
        ["task", "endtask"]
    ],
    "autoClosingPairs": [
        {"open":"(", "close":")", "notIn":["string", "comment"]},
        {"open":"[", "close":"]", "notIn":["string", "comment"]},
        {"open":"{", "close":"}", "notIn":["string", "comment"]},
        {"open":"\"", "close":"\"", "notIn":["string"]}
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["'", "'"],
        ["\"", "\""]
    ]
}